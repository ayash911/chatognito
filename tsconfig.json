{
  "compilerOptions": {
    "target": "es2022",
    "module": "commonjs",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@chatognito/database": ["backend/packages/database/src"],
      "@chatognito/logger": ["backend/packages/logger/src"]
    }
  },
  "exclude": ["node_modules", "**/dist"]
}
