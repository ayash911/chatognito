{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "sourceMap": true,
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "@auth/*": ["auth/src/*"],
      "@common/*": ["common/src/*"],
      "@messaging/*": ["messaging/src/*"],
      "@social/*": ["social/src/*"],
      "@chatognito/crypto": ["../packages/crypto/src/index.ts"]
    }
  },
  "include": ["*/src/**/*.ts", "tests/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
