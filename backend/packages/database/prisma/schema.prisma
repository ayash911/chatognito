generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                   String    @unique @db.VarChar(255)
  passwordHash            String?   @map("password_hash") @db.VarChar(255)
  username                String?   @unique @db.VarChar(50)
  usernameLastChangedAt   DateTime? @map("username_last_changed_at") @db.Timestamptz
  displayName             String?   @map("display_name") @db.VarChar(100)
  bio                     String?   @db.Text
  avatarUrl               String?   @map("avatar_url") @db.VarChar(1024)
  bannerUrl               String?   @map("banner_url") @db.VarChar(1024)
  isPrivate               Boolean   @default(false) @map("is_private")
  twoFactorSecret         String?   @map("two_factor_secret") @db.VarChar(255)
  twoFactorEnabled        Boolean   @default(false) @map("two_factor_enabled")
  createdAt               DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt               DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt               DateTime? @map("deleted_at") @db.Timestamptz

  oauthIdentities         OAuthIdentity[]
  usernameHistory         UsernameHistory[]
  conversations           ConversationParticipant[]
  messagesSent            Message[]

  // Social Relations
  followers               Follow[] @relation("following")
  following               Follow[] @relation("follower")
  blockedUsers            Block[]  @relation("blocker")
  blockedBy               Block[]  @relation("blocked")
  keyBundle               KeyBundle?

  @@map("users")
  @@index([username])
  @@index([email])
}

enum OAuthProvider {
  google
  apple

  @@map("oauth_provider")
}

model OAuthIdentity {
  id         String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String        @map("user_id") @db.Uuid
  provider   OAuthProvider
  providerId String        @map("provider_id") @db.VarChar(255)
  createdAt  DateTime      @default(now()) @map("created_at") @db.Timestamptz

  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId])
  @@map("oauth_identities")
}

model UsernameHistory {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  oldUsername String   @map("old_username") @db.VarChar(50)
  changedAt   DateTime @default(now()) @map("changed_at") @db.Timestamptz

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("username_history")
  @@index([userId])
}

// -----------------------------------------------------------------------------
// SOCIAL DOMAIN
// -----------------------------------------------------------------------------

model Follow {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  followerId  String   @map("follower_id") @db.Uuid
  followingId String   @map("following_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  follower    User     @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@map("follows")
  @@index([followerId])
  @@index([followingId])
}

model Block {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  blockerId   String   @map("blocker_id") @db.Uuid
  blockedId   String   @map("blocked_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  blocker     User     @relation("blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked     User     @relation("blocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@map("blocks")
  @@index([blockerId])
  @@index([blockedId])
}

// -----------------------------------------------------------------------------
// MESSAGING DOMAIN
// -----------------------------------------------------------------------------

enum ConversationType {
  direct
  group

  @@map("conversation_type")
}

model Conversation {
  id        String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type      ConversationType @default(direct)
  title     String?          @db.VarChar(100) // Only for group chats
  createdAt DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime         @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  participants ConversationParticipant[]
  messages     Message[]

  @@map("conversations")
}

enum ParticipantRole {
  member
  admin

  @@map("participant_role")
}

model ConversationParticipant {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversationId String          @map("conversation_id") @db.Uuid
  userId         String          @map("user_id") @db.Uuid
  role           ParticipantRole @default(member)
  joinedAt       DateTime        @default(now()) @map("joined_at") @db.Timestamptz
  lastReadAt     DateTime?       @map("last_read_at") @db.Timestamptz

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@map("conversation_participants")
  @@index([userId])
}

model Message {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversationId String    @map("conversation_id") @db.Uuid
  senderId       String    @map("sender_id") @db.Uuid
  content          String    @db.Text
  isEncrypted      Boolean   @default(false) @map("is_encrypted")
  encryptionHeader String?   @map("encryption_header") @db.Text
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@map("messages")
  @@index([conversationId, createdAt])
  @@index([senderId])
}

// -----------------------------------------------------------------------------
// SECURITY DOMAIN
// -----------------------------------------------------------------------------

model KeyBundle {
  userId                String   @id @map("user_id") @db.Uuid
  identityPublicKey     String   @map("identity_public_key") @db.Text
  signedPreKey          String   @map("signed_pre_key") @db.Text
  signedPreKeySignature String   @map("signed_pre_key_signature") @db.Text
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  oneTimePreKeys        OneTimePreKey[]
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("key_bundles")
}

model OneTimePreKey {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  publicKey String   @map("public_key") @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  keyBundle KeyBundle @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@map("one_time_pre_keys")
}
